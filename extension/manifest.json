{
  "manifest_version": 3,
  "name": "TraceX Website Blocker",
  "version": "1.0",
  "description": "Blocks distracting websites and syncs with TraceX Focus System.",
  "permissions": [
    "tabs",
    "storage",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}